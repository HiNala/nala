# Nala Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit API keys.

# ── LLM Provider ──────────────────────────────────────────────────────────
# Which provider to use: anthropic | openai | google | ollama
LLM_PROVIDER=anthropic

# Anthropic (Claude) — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (GPT) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google (Gemini) — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash

# Ollama (local, no API key needed) — https://ollama.com
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=codellama:13b

# ── Neo4j Code Graph (optional) ───────────────────────────────────────────
# Leave these commented out to run without graph features.
# Neo4j is used for dependency analysis, dead code detection, etc.
# Download: https://neo4j.com/download/
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password

# ── Dashboard (optional) ──────────────────────────────────────────────────
# DASHBOARD_PORT=3000
