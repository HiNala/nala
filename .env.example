# Nala environment configuration
# Copy this file to .env and fill in your API keys.
# .env is gitignored — never commit it.
#
# TIP: You can also use `/settings setup` inside Nala to configure
# everything interactively, which writes to .nala/settings.toml.
# Environment variables here always take precedence over settings.toml.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: anthropic, openai, google, ollama
LLM_PROVIDER=anthropic

# ── API Keys (set the one matching your provider) ─────────────────────────────

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.0-flash

# Ollama (local, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=codellama:13b

# ── Multi-model routing (optional, per-task overrides) ────────────────────────
# Format: ROUTE_<TASK>=<provider>:<model>
# ROUTE_PLAN=anthropic:claude-opus-4-6
# ROUTE_CODE=openai:gpt-4o
# ROUTE_EXPLORE=openai:gpt-4o-mini
# ROUTE_RESEARCH=anthropic:claude-sonnet-4-6
# ROUTE_REVIEW=anthropic:claude-sonnet-4-6
# ROUTE_SUMMARIZE=google:gemini-2.0-flash

# ── Optional ──────────────────────────────────────────────────────────────────

# Neo4j code graph (SQLite used as fallback)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-password

# Dashboard
# DASHBOARD_PORT=3000
